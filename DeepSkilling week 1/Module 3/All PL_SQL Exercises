/*******************************************************************************
  DATABASE CLEAN REBOOT
  (Drops existing tables to prevent "table already exists" errors)
*******************************************************************************/
DROP TABLE IF EXISTS AuditLog;
DROP TABLE IF EXISTS Employees;
DROP TABLE IF EXISTS Loans;
DROP TABLE IF EXISTS Transactions;
DROP TABLE IF EXISTS Accounts;
DROP TABLE IF EXISTS Customers;

/*******************************************************************************
  DATABASE CORE TABLES INFRASTRUCTURE SCHEMA
*******************************************************************************/

-- [Table 1: Customers Storage]
CREATE TABLE Customers (
    CustomerID INTEGER PRIMARY KEY,
    Name TEXT,
    DOB TEXT,
    Balance REAL,
    LastModified TEXT,
    IsVIP TEXT DEFAULT 'FALSE'
);

-- [Table 2: Financial Accounts Storage]
CREATE TABLE Accounts (
    AccountID INTEGER PRIMARY KEY,
    CustomerID INTEGER,
    AccountType TEXT,
    Balance REAL,
    LastModified TEXT,
    FOREIGN KEY (CustomerID) REFERENCES Customers(CustomerID)
);

-- [Table 3: Transactions Ledger]
CREATE TABLE Transactions (
    TransactionID INTEGER PRIMARY KEY,
    AccountID INTEGER,
    TransactionDate TEXT,
    Amount REAL,
    TransactionType TEXT,
    FOREIGN KEY (AccountID) REFERENCES Accounts(AccountID)
);

-- [Table 4: Debt & Loans Tracking]
CREATE TABLE Loans (
    LoanID INTEGER PRIMARY KEY,
    CustomerID INTEGER,
    LoanAmount REAL,
    InterestRate REAL,
    StartDate TEXT,
    EndDate TEXT,
    FOREIGN KEY (CustomerID) REFERENCES Customers(CustomerID)
);

-- [Table 5: Enterprise Employees Ledger]
CREATE TABLE Employees (
    EmployeeID INTEGER PRIMARY KEY,
    Name TEXT,
    Position TEXT,
    Salary REAL,
    Department TEXT,
    HireDate TEXT
);

-- [Table 6: Automation Event Audit Logging]
CREATE TABLE AuditLog (
    LogID INTEGER PRIMARY KEY AUTOINCREMENT,
    TransactionID INTEGER,
    AccountID INTEGER,
    Amount REAL,
    TransactionType TEXT,
    LogDate TEXT
);

