/*******************************************************************************
  EXERCISE 5: AUTOMATED TRIGGER DATA RULES
*******************************************************************************/

-- [EXERCISE 5 - SCENARIO 1: UpdateCustomerLastModified Sync Rule]
CREATE TRIGGER Trg_UpdateCustomerLastModified
AFTER UPDATE ON Customers
BEGIN
    UPDATE Customers SET LastModified = date('now') WHERE CustomerID = NEW.CustomerID;
END;

-- [EXERCISE 5 - SCENARIO 2: LogTransaction Automated Audit Pipeline]
CREATE TRIGGER Trg_LogTransaction
AFTER INSERT ON Transactions
BEGIN
    INSERT INTO AuditLog (TransactionID, AccountID, Amount, TransactionType, LogDate)
    VALUES (NEW.TransactionID, NEW.AccountID, NEW.Amount, NEW.TransactionType, date('now'));
END;

-- [EXERCISE 5 - SCENARIO 3: CheckTransactionRules Business Policy Validation]
CREATE TRIGGER Trg_CheckTransactionRules
BEFORE INSERT ON Transactions
BEGIN
    SELECT CASE 
        WHEN NEW.TransactionType = 'Deposit' AND NEW.Amount <= 0 
        THEN RAISE(ABORT, 'Deposit amount must be positive.')
        WHEN NEW.TransactionType = 'Withdrawal' AND NEW.Amount > (SELECT Balance FROM Accounts WHERE AccountID = NEW.AccountID)
        THEN RAISE(ABORT, 'Withdrawal exceeds current balance.')
    END;
END;


